# Volta-Sim Environment Configuration

# Renode
RENODE_VERSION=1.15.2
RENODE_TELNET_PORT=1234
RENODE_GDB_PORT=3333

# voltad
VOLTAD_SHM_PATH=/dev/shm/volta_peripheral_state
VOLTAD_SHM_SIZE=65536
VOLTAD_ZMQ_PUB_PORT=5555
VOLTAD_GRPC_PORT=50051
VOLTAD_POLL_INTERVAL_US=100

# API
API_PORT=8080

# Web
WEB_PORT=3001

# UE5 Pixel Streaming (optional — docker-compose -f ... -f docker-compose.ue5.yml)
# Requires: NVIDIA GPU, packaged game in packaged-game/
PIXEL_STREAM_PORT=8888

# Logging
LOG_LEVEL=info
